{
  "manifest_version": 3,
  "name": "Leecher Session Capture",
  "version": "1.0",
  "description": "Capture browser session (cookies + headers) for a URL and push to a GitHub Gist for the Colab Leecher bot to use.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
